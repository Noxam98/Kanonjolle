---
const links = [
  { href: "#om-oss", label: "Om oss" },
  { href: "#var-bat", label: "Vår båt" },
  { href: "#aktiviteter", label: "Aktiviteter" },
  { href: "#kontakt", label: "Kontakt" },
];
---

<header class="fixed top-0 left-0 w-full z-50 transition-all duration-300" id="site-header">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <div class="w-10 h-10 rounded-full border-2 border-sand-300/40 group-hover:border-sand-300 transition-colors flex items-center justify-center p-1.5">
        <div class="w-full h-full opacity-60 group-hover:opacity-90 transition-opacity" style="background-color: rgb(201,187,166); mask-image: url('/historien/silhouette.png'), url('/historien/silhouette.png'); mask-mode: luminance, alpha; mask-composite: exclude; mask-size: contain, contain; mask-repeat: no-repeat; mask-position: center; -webkit-mask-image: url('/historien/silhouette.png'), url('/historien/silhouette.png'); -webkit-mask-mode: luminance, alpha; -webkit-mask-composite: xor; -webkit-mask-size: contain, contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center;"></div>
      </div>
      <span class="hidden sm:block text-sand-200 text-sm font-light tracking-widest uppercase">
        Kystens Bevoktere
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a href={link.href} data-nav-link={link.href.slice(1)} class="nav-link relative text-sand-300/70 hover:text-sand-100 text-sm tracking-wide transition-colors duration-200 after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-px after:bg-sand-300 after:transition-all after:duration-300">
          {link.label}
        </a>
      ))}
    </nav>

    <button class="md:hidden text-sand-300 p-2" id="mobile-menu-btn" aria-label="Meny">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div class="md:hidden hidden bg-navy-950/95 backdrop-blur-md border-t border-sand-300/10" id="mobile-menu">
    <nav class="flex flex-col px-6 py-4 gap-4">
      {links.map((link) => (
        <a href={link.href} class="text-sand-300/70 hover:text-sand-100 text-sm tracking-wide transition-colors">
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById("site-header");
  if (header) {
    window.addEventListener("scroll", () => {
      header.classList.toggle("bg-navy-950/90", window.scrollY > 50);
      header.classList.toggle("backdrop-blur-md", window.scrollY > 50);
    });
  }

  // Active nav link via IntersectionObserver
  const navLinks = document.querySelectorAll<HTMLAnchorElement>(".nav-link");
  const sections = ["om-oss", "var-bat", "aktiviteter", "kontakt"]
    .map((id) => document.getElementById(id))
    .filter(Boolean) as HTMLElement[];

  const setActive = (id: string) => {
    navLinks.forEach((a) => {
      const isActive = a.dataset.navLink === id;
      a.classList.toggle("text-sand-100", isActive);
      a.classList.toggle("text-sand-300/70", !isActive);
      a.style.setProperty("--tw-after-w", isActive ? "100%" : "0%");
      a.classList.toggle("after:w-full", isActive);
      a.classList.toggle("after:w-0", !isActive);
    });
  };

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) setActive(entry.target.id);
      });
    },
    { rootMargin: "-40% 0px -55% 0px", threshold: 0 }
  );
  sections.forEach((s) => observer.observe(s));

  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  if (btn && menu) {
    btn.addEventListener("click", () => menu.classList.toggle("hidden"));
    menu.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => menu.classList.add("hidden")));
  }
</script>
