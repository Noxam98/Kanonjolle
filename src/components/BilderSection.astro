---
---

<section id="bilder" class="relative z-10 bg-navy-950 py-24 sm:py-32 border-t border-sand-300/10">
  <div class="max-w-5xl mx-auto px-6">
    <div data-aos="fade-up">
      <p class="text-sand-500 text-xs tracking-[0.3em] uppercase mb-4 font-light">03</p>
      <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-sand-50 mb-6">Bilder</h2>
      <div class="w-12 h-px bg-sand-400/40 mb-8"></div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-4" data-aos="fade-up" data-aos-delay="200" id="gallery-grid">
      {Array.from({ length: 9 }).map((_, i) => (
        <button
          class="gallery-thumb aspect-4/3 bg-navy-900/50 border border-sand-300/10 rounded-sm flex items-center justify-center overflow-hidden cursor-pointer group relative"
          data-index={i}
        >
          <img
            src={`/gallery/bilde-${i + 1}.jpg`}
            alt={`Bilde ${i + 1}`}
            class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
            onload="this.style.opacity='1'"
            onerror="this.style.display='none'"
          />
          <svg class="w-8 h-8 text-sand-400/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </button>
      ))}
    </div>
  </div>
</section>

<!-- Lightbox -->
<div id="lightbox" class="fixed inset-0 z-[100] hidden bg-navy-950/95 backdrop-blur-md" role="dialog" aria-modal="true" aria-label="Bildevisning">
  <button id="lb-close" class="absolute top-4 right-4 z-10 w-10 h-10 flex items-center justify-center text-sand-300/70 hover:text-sand-100 transition-colors" aria-label="Lukk">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  <div class="absolute top-4 left-4 z-10 text-sand-400/60 text-sm tracking-wide">
    <span id="lb-current">1</span> / <span id="lb-total">9</span>
  </div>
  <button id="lb-prev" class="absolute left-2 sm:left-6 top-1/2 -translate-y-1/2 z-10 w-10 h-10 flex items-center justify-center text-sand-300/50 hover:text-sand-100 transition-colors" aria-label="Forrige bilde">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" /></svg>
  </button>
  <button id="lb-next" class="absolute right-2 sm:right-6 top-1/2 -translate-y-1/2 z-10 w-10 h-10 flex items-center justify-center text-sand-300/50 hover:text-sand-100 transition-colors" aria-label="Neste bilde">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" /></svg>
  </button>
  <div id="lb-container" class="absolute inset-0 flex items-center justify-center p-4 sm:p-16">
    <img id="lb-img" src="" alt="" class="max-w-full max-h-full object-contain select-none transition-[transform,opacity] duration-300" draggable="false" />
  </div>
  <div id="lb-hint" class="absolute bottom-6 left-1/2 -translate-x-1/2 text-sand-400/40 text-xs tracking-wide pointer-events-none transition-opacity duration-500">
    ← sveip for å bla · sveip opp/ned for å lukke →
  </div>
</div>

<script>
  const lightbox = document.getElementById("lightbox")!;
  const lbImg = document.getElementById("lb-img") as HTMLImageElement;
  const lbClose = document.getElementById("lb-close")!;
  const lbPrev = document.getElementById("lb-prev")!;
  const lbNext = document.getElementById("lb-next")!;
  const lbCurrent = document.getElementById("lb-current")!;
  const lbTotal = document.getElementById("lb-total")!;
  const lbContainer = document.getElementById("lb-container")!;
  const lbHint = document.getElementById("lb-hint")!;

  const thumbs = document.querySelectorAll<HTMLButtonElement>(".gallery-thumb");
  const images = Array.from({ length: 9 }, (_, i) => `/gallery/bilde-${i + 1}.jpg`);
  let current = 0;
  let hintShown = false;

  function showImage(index: number) {
    current = ((index % images.length) + images.length) % images.length;
    lbImg.style.opacity = "0";
    lbImg.style.transform = "scale(0.95)";
    setTimeout(() => {
      lbImg.src = images[current];
      lbImg.alt = `Bilde ${current + 1}`;
      lbImg.style.opacity = "1";
      lbImg.style.transform = "scale(1) translate(0px,0px)";
    }, 150);
    lbCurrent.textContent = String(current + 1);
  }

  function openLightbox(index: number) {
    showImage(index);
    lbTotal.textContent = String(images.length);
    lightbox.classList.remove("hidden");
    document.body.style.overflow = "hidden";
    if (!hintShown) { hintShown = true; setTimeout(() => { lbHint.style.opacity = "0"; }, 2500); }
  }

  function closeLightbox() {
    lightbox.classList.add("hidden");
    document.body.style.overflow = "";
    lbImg.style.transform = "scale(1) translate(0px,0px)";
  }

  thumbs.forEach((t) => t.addEventListener("click", () => openLightbox(Number(t.dataset.index))));
  lbClose.addEventListener("click", closeLightbox);
  lbPrev.addEventListener("click", () => showImage(current - 1));
  lbNext.addEventListener("click", () => showImage(current + 1));
  lbContainer.addEventListener("click", (e) => { if (e.target === lbContainer) closeLightbox(); });
  document.addEventListener("keydown", (e) => {
    if (lightbox.classList.contains("hidden")) return;
    if (e.key === "Escape") closeLightbox();
    if (e.key === "ArrowLeft") showImage(current - 1);
    if (e.key === "ArrowRight") showImage(current + 1);
  });

  // Swipe
  let tx = 0, ty = 0, dx = 0, dy = 0, swiping = false;
  const THRESHOLD = 50;
  lbContainer.addEventListener("touchstart", (e) => {
    tx = e.touches[0].clientX; ty = e.touches[0].clientY;
    dx = dy = 0; swiping = true; lbImg.style.transition = "none";
  }, { passive: true });
  lbContainer.addEventListener("touchmove", (e) => {
    if (!swiping) return;
    dx = e.touches[0].clientX - tx; dy = e.touches[0].clientY - ty;
    if (Math.abs(dx) > Math.abs(dy)) {
      lbImg.style.transform = `scale(1) translate(${dx}px,0px)`;
    } else {
      lbImg.style.opacity = String(Math.max(0, 1 - Math.abs(dy) / 300));
      lbImg.style.transform = `scale(1) translate(0px,${dy}px)`;
    }
  }, { passive: true });
  lbContainer.addEventListener("touchend", () => {
    if (!swiping) return;
    swiping = false;
    lbImg.style.transition = "transform 0.3s ease, opacity 0.3s ease";
    if (Math.abs(dy) > Math.abs(dx) && Math.abs(dy) > THRESHOLD) {
      lbImg.style.transform = `scale(0.8) translate(0px,${(dy > 0 ? 1 : -1) * 400}px)`;
      lbImg.style.opacity = "0";
      setTimeout(closeLightbox, 200);
    } else if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > THRESHOLD) {
      showImage(dx < 0 ? current + 1 : current - 1);
    } else {
      lbImg.style.transform = "scale(1) translate(0px,0px)";
      lbImg.style.opacity = "1";
    }
  });
</script>
