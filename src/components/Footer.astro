---
const year = new Date().getFullYear();
---

<footer class="relative z-10 bg-navy-950 border-t border-sand-300/10 py-12">
  <div class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sand-500/40 text-xs tracking-wide flex items-center gap-3 flex-wrap">
      <span>Laget av Maksym Melnykov</span>
      <a href="mailto:meliqq98@gmail.com" class="inline-flex items-center gap-1 underline underline-offset-2 hover:text-sand-300/60 transition-colors" title="Send e-post">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </a>
      <a href="tel:+47802980" class="inline-flex items-center gap-1 underline underline-offset-2 hover:text-sand-300/60 transition-colors" title="Ring">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
      </a>
    </p>
    <p class="text-sand-500/60 text-xs tracking-wide">&copy; {year} Kystens Bevoktere — Øster Riisøer – Vester Riisøer</p>
    <div class="w-6 h-6 rounded-full border border-sand-400/20 flex items-center justify-center">
      <span class="text-sand-400/40 font-serif text-[10px] font-bold">KB</span>
    </div>
  </div>
</footer>
