---
---

<section id="kontakt" class="relative z-10 bg-navy-950 py-24 sm:py-32 border-t border-sand-300/10">
  <div class="max-w-5xl mx-auto px-6">
    <div data-aos="fade-up">
      <p class="text-sand-500 text-xs tracking-[0.3em] uppercase mb-4 font-light">05</p>
      <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-sand-50 mb-6">Kontakt</h2>
      <div class="w-12 h-px bg-sand-400/40 mb-8"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-8" data-aos="fade-up" data-aos-delay="200">
      <!-- Address -->
      <div class="bg-navy-900/40 border border-sand-300/10 rounded-sm p-8 sm:p-10">
        <p class="text-sand-400/60 text-xs tracking-[0.25em] uppercase mb-6 font-light">Besøksadresse</p>
        <div class="flex items-start gap-4 mb-6">
          <svg class="w-5 h-5 text-sand-400/50 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <div>
            <p class="text-sand-200/90 text-sm leading-relaxed">Øster Riisøer 3</p>
            <p class="text-sand-200/90 text-sm leading-relaxed">Risør, Norge</p>
          </div>
        </div>
        <div class="w-full h-px bg-sand-300/10 mb-6"></div>
        <p class="text-sand-400/50 text-xs leading-relaxed">
          Foreningen Kystens Bevoktere holder til i Risør og opererer i de historiske farvannene langs Aust-Agder-kysten.
        </p>
      </div>

      <!-- Facebook contact -->
      <div class="bg-navy-900/40 border border-sand-300/10 rounded-sm p-8 sm:p-10">
        <p class="text-sand-400/60 text-xs tracking-[0.25em] uppercase mb-6 font-light">Ta kontakt</p>
        <p class="text-sand-300/70 text-sm leading-relaxed mb-8">
          Følg oss på Facebook og send oss en melding — vi svarer raskt via Messenger.
        </p>
        <a
          href="https://www.facebook.com/KYSTENSBEVOKTERE/"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-3 bg-[#1877f2]/10 hover:bg-[#1877f2]/20 border border-[#1877f2]/30 hover:border-[#1877f2]/60 text-sand-200 hover:text-white text-sm tracking-wide px-6 py-4 rounded-sm transition-all duration-200 group"
        >
          <svg class="w-5 h-5 text-[#1877f2]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          <span>Send melding på Facebook</span>
          <svg class="w-4 h-4 text-sand-400/60 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <p class="text-sand-400/40 text-xs mt-4 tracking-wide">
          facebook.com/KYSTENSBEVOKTERE
        </p>
      </div>
    </div>
  </div>
</section>
